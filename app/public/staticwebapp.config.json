{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/audio/*", "/assets/*", "/*.{png,svg,ico,json,webmanifest}"]
  },
  "platform": {
    "apiRuntime": "node:22"
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "routes": [
    {
      "route": "/api/*",
      "headers": {
        "Cache-Control": "no-store"
      }
    }
  ]
}
